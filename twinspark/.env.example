# TwinSpark configuration
# Copy this file to `.env` and fill in your own values. Never commit `.env`.

# Required: your DashScope (Alibaba Bailian) API key.
DASHSCOPE_API_KEY=your-key-here

# Optional: OpenAI-compatible endpoint base URL.
# TWINSPARK_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# Optional: default model name.
# TWINSPARK_MODEL=qwen-plus

# Optional: local SQLite state database path.
# TWINSPARK_DB_PATH=~/.twinspark/state.db

# Optional: directory holding user skills.
# TWINSPARK_SKILLS_DIR=~/.twinspark/skills/

# --- DingTalk Bot ---
# Integration mode: disabled / stream / webhook
# - stream:  Recommended. Uses WebSocket, no public URL or ICP filing needed.
# - webhook: Requires public HTTPS endpoint + ICP filing in mainland China.
# - disabled: DingTalk integration off (default).
# DINGTALK_MODE=disabled

# DingTalk app credentials (shared by both stream and webhook modes)
# DINGTALK_APP_KEY=your-app-key
# DINGTALK_APP_SECRET=your-dingtalk-robot-app-secret

# Webhook-only: signature verification (not needed for stream mode)
# DINGTALK_VERIFY_SIGNATURE=true

# --- DingTalk AI Card (optional, works with both stream and webhook) ---
# DINGTALK_CARD_TEMPLATE_ID=your-card-template-id
# DINGTALK_MESSAGE_MODE=text          # text | card | auto
# DINGTALK_STREAM_INTERVAL_MS=500     # card streaming update interval (ms)

# ─── MCP 配置 ───────────────────────────────────────
# 启用 MCP 客户端功能（连接外部 MCP 服务器）
# TWINSPARK_MCP_ENABLED=true
# MCP 服务器配置文件路径（默认 ~/.twinspark/mcp-servers.yaml）
# TWINSPARK_MCP_CONFIG_PATH=~/.twinspark/mcp-servers.yaml
